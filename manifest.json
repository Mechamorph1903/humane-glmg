{
  "manifest_version": 3,
  "name": "AccessAI",
  "version": "1.0",
  "description": "AI-powered screen reader that summarizes any webpage and reads it aloud",

 
  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": [
  ],

  "host_permissions": [
  ]
}
