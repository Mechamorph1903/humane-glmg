{
  "manifest_version": 3,
  "name": "Lazey",
  "version": "1.0",
  "description": "AI-powered screen reader that summarizes any webpage and reads it aloud",

  "background": {
    "service_worker": "background.js",
    "scripts": ["config.js", "background.js"],
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "extension-pic.png"
  },

  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": [
    "activeTab",        
    "scripting",        
    "storage"           
  ],

  "host_permissions": [
    "https://api.anthropic.com/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "accessai@humane-glmg",
      "strict_min_version": "109.0"
    }
  }
}
  